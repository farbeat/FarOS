menu "Audio API Config"

config SAP_DUMP_SUPPORT
    bool "enable dump"
    default n
    help
        enable dump in MPI

config SAP_AI_DUMP_SUPPORT
    bool "ai dump support"
    default n
    depends on SAP_DUMP_SUPPORT
    help
        enable ai dump in MPI

