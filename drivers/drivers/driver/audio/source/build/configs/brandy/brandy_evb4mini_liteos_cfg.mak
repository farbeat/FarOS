# CFG_SAP_ANC_CODEC_I2C_ADDR is not set
# end of ANC_CODEC Driver

#
# aw88262 Driver
#
CFG_SAP_VENDOR_DRIVER_AW88262_SUPPORT=y
CFG_SAP_CONTROL_AW88262_IN_ACORE=y
# CFG_SAP_CONTROL_AW88262_IN_DSP is not support
CFG_SAP_AW88262_I2C_BUS_ID=3
CFG_SAP_AW88262_I2C_ADDR=0x30
# end of aw88262 Driver

#
# aw88166 Driver
#
CFG_SAP_VENDOR_DRIVER_AW88166_SUPPORT=y
CFG_SAP_CONTROL_AW88166_IN_ACORE=y
# CFG_SAP_CONTROL_AW88166_IN_DSP is not support
CFG_SAP_AW88166_I2C_BUS_ID=0
CFG_SAP_AW88166_I2C_ADDR=0x34
# end of aw88166 Driver

#
# es8156 Driver
#
# CFG_SAP_VENDOR_DRIVER_ES8156_SUPPORT is not set
# end of es8156 Driver

#
# es8311 Driver
#
# CFG_SAP_VENDOR_DRIVER_ES8311_SUPPORT is not set
# end of es8311 Driver

#
# es8396 Driver
