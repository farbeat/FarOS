#
# dsp version
#
CFG_SAP_DSP_VERSION="B501"

#
# Audio Base Config
#
# CFG_SAP_FPGA is not set
CFG_SAP_LITEOS_PRODUCT=y
# CFG_SAP_LINUX_PRODUCT is not set
# CFG_SAP_ANDROID_PRODUCT is not set
CFG_SAP_PRODUCT_TYPE=liteos
# CFG_SAP_SHAOLINCLAW is not set
# CFG_SAP_WUDANGSTICK is not set
CFG_SAP_CHIP_TYPE=brandy
CFG_SAP_BOARD_TYPE=evb4mini

#
# CPU Config
#
CFG_SAP_CPU_ARCH_RISCV=y
# CFG_SAP_CPU_ARCH_ARM is not set
# CFG_SAP_CPU_ARCH_ARM64 is not set
CFG_SAP_CPU_ARCH=riscv
CFG_SAP_CPU_OS_LITEOS=y
# CFG_SAP_CPU_OS_LINUX is not set
CFG_SAP_CPU_OS=liteos
# CFG_SAP_PROTOCOL_CORE_SUPPORT is not set

#
# DSP Config
#
# CFG_SAP_DSP_ARCH_HIFI3 is not set
CFG_SAP_DSP_ARCH_HIFI3Z=y
# CFG_SAP_DSP_ARCH_HIFI5 is not set
CFG_SAP_DSP_ARCH=hifi3z
CFG_SAP_DSP_OS_XTENSA=y
# CFG_SAP_DSP_OS_LITEOS is not set
CFG_SAP_DSP_OS=xtensa
CFG_SAP_DSP_CLK_HZ=147456000
CFG_SAP_DSP_FRIMWARE_NAME=dsp

#
# DSP LSP Config
#
CFG_SAP_DSP_LSP_MAIN=lsp_main_mini
# CFG_SAP_DSP_LSP_MAIN1 is not set
CFG_SAP_DSP_LSP_SEA=lsp_sea_mini
CFG_SAP_DSP_LSP_AAI=lsp_aai
CFG_SAP_DSP_LSP_AEF=lsp_aef_mini
# CFG_SAP_DSP_LSP_HAID is not set
CFG_SAP_DSP_LSP_CODEC=lsp_codec
CFG_SAP_DSP_LSP_EXTCODEC=lsp_extcodec

#
# Audio Driver Config
#
CFG_SAP_PROC_SUPPORT=y
CFG_SAP_PROC_TYPE_DUMMY=y
# CFG_SAP_PROC_TYPE_REAL is not set
CFG_SAP_PROC_OUTPUT_UART=y
CFG_SAP_PROC_OUTPUT_DIAG_SHELL=y
# CFG_SAP_PROFILE_SUPPORT is not set
# CFG_SAP_TIME_CONSUME is not set
CFG_SAP_SYNC_STATUS_SUPPORT=y
# CFG_SAP_MEM_STATISTIC is not set
# CFG_SAP_MCPS_STATISTIC is not set
# CFG_SAP_ANC_SUPPORT is not set
# CFG_SAP_LPC_SUPPORT is not set
# CFG_SAP_DSP_I2C_SUPPORT is not set
# CFG_SAP_FLASH_FIRMWARE_SUPPORT is not set
# CFG_SAP_SHELL_SUPPORT is not set
# CFG_SAP_TEST_CORE_SUPPORT is not set
# CFG_SAP_HAID_SUPPORT is not set
# CFG_SAP_BINAURAL_SYNC_SUPPORT is not set
CFG_SAP_SUPPORT_RT_SMALL_MEM=y

#
# Audio Log Config
#

CFG_SAP_IPC_LOG_SUPPORT=y
CFG_SAP_DIAG_LOG_SUPPORT=y

#
# Audio Vendor Drivers
#
CFG_SAP_VENDOR_DRIVER_SUPPORT=y
CFG_SAP_VENDOR_I2S0_TX_CODEC="aw88166"
CFG_SAP_VENDOR_I2S2_TX_CODEC="aw88262"

#
# ANC_CODEC Driver
#
# CFG_SAP_VENDOR_DRIVER_ANC_CODEC_SUPPORT is not support
